# Trimlight cloud API credentials (required — contact Trimlight to obtain)
TRIMLIGHT_CLIENT_ID=your_client_id
TRIMLIGHT_CLIENT_SECRET=your_client_secret

# Trimlight device ID (required — find via the API's device list endpoint)
TRIMLIGHT_DEVICE_ID=your_device_id

# Trimlight API base URL (default is the production cloud endpoint)
TRIMLIGHT_API_URL=https://trimlight.ledhue.com/trimlight

# HTTP port — serves the status UI, webhook receiver, and test endpoint
WEBHOOK_PORT=8484

# Seconds before auto-restoring lights after alarm
ALARM_TIMEOUT=30

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
