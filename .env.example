# Trimlight controller IP (required)
TRIMLIGHT_HOST=192.168.1.100

# Trimlight TCP port
TRIMLIGHT_PORT=8189

# HTTP webhook listener port
WEBHOOK_PORT=8080

# Seconds before auto-restoring lights after alarm
ALARM_TIMEOUT=30

# Webhook trigger type to match (from UniFi Protect alarm payload)
TRIGGER_KEY=animal

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
